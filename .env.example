# ---- LLM providers (both are OpenAI-compatible) ----
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# NVIDIA NIM: https://build.nvidia.com (Get API Key)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ---- App ----
# Comma-separated provider order for fallback when a route's primary provider fails.
LLM_FALLBACK_ORDER=openrouter,nvidia_nim
# Number of leads processed concurrently per job.
PIPELINE_CONCURRENCY=4
# Quality score (out of 10) at/above which a lead is counted "high quality".
QUALITY_THRESHOLD=8.0
# SQLite database URL.
DATABASE_URL=sqlite+aiosqlite:///./leadforge.db
# Directory where uploaded files are stored.
UPLOAD_DIR=./uploads

# ---- Auth ----
# Secret that signs the session cookie. Generate one: python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=dev-insecure-change-me
# First admin, created automatically on first run if no users exist yet.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# If set, /webhooks/* require this secret via ?secret= or the X-Webhook-Secret header.
WEBHOOK_SECRET=

# ---- Job queue ----
# inprocess: built-in asyncio worker (default; resumes interrupted jobs on restart).
# arq: Redis-backed durable queue that scales horizontally. Requires `pip install arq`,
# a running Redis at REDIS_URL, and a worker process:
#   arq app.pipeline.arq_worker.WorkerSettings
QUEUE_BACKEND=inprocess
REDIS_URL=redis://localhost:6379

# ---- Email channel ----
# console = log only (no real send); switch to smtp or resend once a mailbox exists.
EMAIL_PROVIDER=console
EMAIL_FROM=outreach@leadforge.ai
EMAIL_FROM_NAME=LeadForge AI
EMAIL_REPLY_TO=
# SMTP (Google Workspace / Microsoft 365 / SES SMTP). Used when EMAIL_PROVIDER=smtp.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
# Resend API (https://resend.com). Used when EMAIL_PROVIDER=resend.
RESEND_API_KEY=

# ---- WhatsApp channel (Meta WhatsApp Business Cloud API) ----
# console = log only; switch to meta once the WhatsApp Business account is ready.
WHATSAPP_PROVIDER=console
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# Pre-approved template name for first contact (Meta policy). Leave blank to send plain text
# (only valid inside the 24h reply window). The generated copy is passed as body param {{1}}.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en_US

# ---- Bulk sending / throttle ----
# Drip rate for queued bulk sends (keep low to protect a young sending domain).
SEND_RATE_PER_HOUR=30
# +/- fraction of randomness applied to the gap between sends (human-looking cadence).
SEND_JITTER=0.3
# Local-time send window [start, end). 0..24 = always. e.g. 9..17 for business hours.
SEND_WINDOW_START_HOUR=0
SEND_WINDOW_END_HOUR=24

# ---- Compliance / public surface ----
# Public base URL used to build the unsubscribe link in every email footer.
PUBLIC_BASE_URL=http://localhost:8000
# Physical postal address — legally required in marketing email (CAN-SPAM).
COMPANY_POSTAL_ADDRESS=LeadForge AI, 123 Example St, City, Country
# Require explicit opt-in before any WhatsApp message (recommended; Meta bans cold blasts).
REQUIRE_OPT_IN_FOR_WHATSAPP=true
